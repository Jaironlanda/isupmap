# Security headers for static assets (HTML/CSS/JS).
# NOTE: these do NOT apply to Worker-generated responses (e.g. /api/*) — those
# headers are set in src/index.ts. See:
# https://developers.cloudflare.com/workers/static-assets/headers/
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-oxcviPPEucw9Mvm0Elf5KaSWSXCQ2h9TKXhMMtI7tmE=' https://www.googletagmanager.com https://unpkg.com https://static.cloudflareinsights.com; connect-src 'self' https://unpkg.com https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com https://cloudflareinsights.com; img-src 'self' data: https://*.google-analytics.com https://www.googletagmanager.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'
