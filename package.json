{
  "name": "isupmap",
  "version": "0.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "deploy": "wrangler deploy && wrangler d1 execute isupmap --remote --file=./schema.sql",
    "dev": "wrangler dev",
    "dev:cron": "wrangler dev --test-scheduled",
    "start": "wrangler dev",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:schema:local": "wrangler d1 execute isupmap --local --file=./schema.sql",
    "db:schema:remote": "wrangler d1 execute isupmap --remote --file=./schema.sql",
    "db:schema:reports:local": "wrangler d1 execute isupmap-reports --local --file=./schema-reports.sql",
    "db:schema:reports:remote": "wrangler d1 execute isupmap-reports --remote --file=./schema-reports.sql"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.12",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.95.0"
  }
}
